## Stage 4: Declarative Pipeline Syntax Reference (Week 2-3)

```groovy
pipeline {
    agent any                    // or: agent { docker { image 'maven:3.9-eclipse-temurin-17' } }

    environment {
        APP_NAME = 'my-app'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    parameters {
        string(name: 'ENV', defaultValue: 'staging', description: 'Target environment')
        booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: '')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    triggers {
        pollSCM('H/5 * * * *')      // poll every ~5 minutes
        // or use a webhook instead (preferred, see Stage 6)
    }

    stages {
        stage('Build') {
            steps { sh 'mvn clean package -DskipTests' }
        }

        stage('Test') {
            when { expression { return !params.SKIP_TESTS } }
            steps { sh 'mvn test' }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    docker.build("myrepo/${APP_NAME}:${IMAGE_TAG}").push()
                }
            }
        }

        stage('Deploy') {
            when { branch 'main' }
            steps {
                sh "kubectl set image deployment/${APP_NAME} ${APP_NAME}=myrepo/${APP_NAME}:${IMAGE_TAG}"
            }
        }
    }

    post {
        always { cleanWs() }
        failure {
            mail to: 'team@example.com', subject: "Build Failed: ${env.JOB_NAME}", body: "Check ${env.BUILD_URL}"
        }
    }
}
```

### Key blocks explained
| Block | Purpose |
|---|---|
| `agent` | Where the pipeline (or a stage) runs — `any`, `none`, `docker { image ... }`, `label 'linux'` |
| `environment` | Env vars available to all steps |
| `parameters` | User inputs when triggering a build manually |
| `when` | Conditional stage execution (branch name, expression, etc.) |
| `post` | Actions after pipeline/stage finishes — `always`, `success`, `failure`, `unstable` |
| `options` | Pipeline-wide settings (timeout, build retention, concurrency) |
| `triggers` | What starts the build automatically (SCM polling, cron, webhook) |

