## Stage 10: Full CI/CD Pipeline — Putting It All Together (Week 7)

The complete flow tying together everything from the Docker and Kubernetes guides:

```groovy
pipeline {
    agent any
    environment {
        IMAGE = "myrepo/spring-boot-demo"
        TAG = "${env.BUILD_NUMBER}"
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Unit Tests') {
            steps { sh 'mvn test' }
            post {
                always { junit 'target/surefire-reports/*.xml' }
            }
        }
        stage('Build Jar') {
            steps { sh 'mvn clean package -DskipTests' }
        }
        stage('Build & Push Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds',
                                                   usernameVariable: 'U', passwordVariable: 'P')]) {
                    sh """
                      docker build -t ${IMAGE}:${TAG} .
                      echo \$P | docker login -u \$U --password-stdin
                      docker push ${IMAGE}:${TAG}
                    """
                }
            }
        }
        stage('Deploy to Kubernetes') {
            when { branch 'main' }
            steps {
                withKubeConfig([credentialsId: 'kubeconfig-creds']) {
                    sh "kubectl set image deployment/spring-boot-demo app=${IMAGE}:${TAG}"
                    sh "kubectl rollout status deployment/spring-boot-demo"
                }
            }
        }
    }
    post {
        failure {
            echo "Pipeline failed — check ${env.BUILD_URL}"
        }
    }
}
```

This is the same chain from the Kubernetes guide's closing table, now fully automated:
**push → test → build jar → build image → push image → rolling update in K8s.**

