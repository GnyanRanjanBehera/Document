## Full kubectl Command Cheat Sheet

```bash
# Cluster & context
kubectl cluster-info
kubectl config get-contexts
kubectl config use-context <name>
kubectl config current-context
kubectl config set-context --current --namespace=<ns>

# Get / describe / delete (works for most resource types)
kubectl get <resource>                  # pods, deployments, services, nodes, pvc, ...
kubectl get <resource> -o yaml          # full YAML of live object
kubectl get <resource> -o json
kubectl get <resource> --watch          # live updates
kubectl describe <resource> <name>
kubectl delete <resource> <name>

# Apply / manage manifests
kubectl apply -f file.yaml
kubectl apply -f ./manifests/           # apply a whole directory
kubectl delete -f file.yaml
kubectl diff -f file.yaml               # preview changes before applying

# Debugging
kubectl logs <pod>
kubectl logs -f <pod>
kubectl logs --previous <pod>           # logs from a crashed container's last run
kubectl exec -it <pod> -- sh
kubectl describe pod <pod>              # events section shows scheduling/pull/probe failures
kubectl get events -A --sort-by=.lastTimestamp
kubectl top pods
kubectl top nodes

# Scaling & rollouts
kubectl scale deployment <name> --replicas=N
kubectl rollout status deployment/<name>
kubectl rollout history deployment/<name>
kubectl rollout undo deployment/<name>

# Networking
kubectl port-forward svc/<service> 8080:80
kubectl port-forward pod/<pod> 8080:8080
kubectl get ingress
kubectl expose deployment <name> --port=80 --target-port=8080 --type=NodePort

# Namespaces
kubectl create namespace <name>
kubectl get all -n <namespace>

# ConfigMaps & Secrets
kubectl create configmap <name> --from-literal=KEY=value
kubectl create secret generic <name> --from-literal=KEY=value
kubectl get secret <name> -o jsonpath='{.data.KEY}' | base64 --decode

# Cleanup
kubectl delete pod --all
kubectl delete deployment --all
kubectl delete namespace <name>         # deletes everything inside it too
```

